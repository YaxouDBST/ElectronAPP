{
  "name": "rachou",
  "version": "1.0.0",
  "description": "Rachou - Un jeu fait par Yaxou pour Rachou",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.rachou.game",
    "productName": "Rachou",
    "win": {
      "target": "nsis",
      "icon": "images/logo.ico",
      "sign": null,
      "signingHashAlgorithms": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "images/logo.ico",
      "uninstallerIcon": "images/logo.ico",
      "shortcutName": "Rachou",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**"
    ]
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "jimp": "^1.6.0",
    "png-to-ico": "^3.0.1"
  }
}
